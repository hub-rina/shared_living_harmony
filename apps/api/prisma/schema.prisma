generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HouseholdRole {
  admin
  member
}

enum SystemRole {
  user
  support
}

enum LandlordMode {
  observer
  caretaker
}

enum MembershipStatus {
  active
  inactive
  invited
}

enum TaskWeight {
  light
  heavy
}

enum TaskStatus {
  pending
  completed
  overdue
}

enum TaskKind {
  routine
  reactive
}

enum TaskCadence {
  once
  weekly
  monthly
}

enum RitualType {
  meal
  event
  checkin
  challenge
}

enum RitualStatus {
  proposed
  completed
}

enum RitualCadence {
  once
  daily
  weekly
}

enum ExpenseShareStatus {
  open
  paid
  confirmed
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  name                 String
  passwordHash         String
  systemRole           SystemRole            @default(user)
  refreshTokenHash     String?
  memberships          HouseholdMember[]
  assignedTasks        Task[]                @relation("TaskAssignee")
  completedTasks       Task[]                @relation("TaskCompleter")
  flaggedTasks         Task[]                @relation("TaskFlagger")
  managedProperties    LandlordProperty[]
  proposedRituals      Ritual[]              @relation("RitualProposer")
  ritualParticipations RitualParticipant[]
  messFlags            MessFlag[]            @relation("MessFlagger")
  membershipChanges    MembershipStatusLog[] @relation("MembershipStatusChanger")
  maintenanceRequests  MaintenanceRequest[]  @relation("MaintenanceReporter")
  createdExpenses      Expense[]             @relation("ExpenseCreator")
  expenseShares        ExpenseShare[]        @relation("ExpenseDebtor")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model Household {
  id            String             @id @default(uuid())
  name          String
  harmonyScore  Int                @default(60)
  lastBloomedAt DateTime?
  joinCode      String             @unique
  members       HouseholdMember[]
  tasks         Task[]
  rituals       Ritual[]
  messFlags     MessFlag[]
  landlords     LandlordProperty[]
  supplies      Supply[]
  maintenance   MaintenanceRequest[]
  expenses      Expense[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

enum MaintenanceStatus {
  open
  acknowledged
  resolved
}

model MaintenanceRequest {
  id          String            @id @default(uuid())
  household   Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  householdId String
  reporter    User              @relation("MaintenanceReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reporterId  String
  title       String
  category    String?
  status      MaintenanceStatus @default(open)
  escalated   Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([householdId])
}

model Supply {
  id          String    @id @default(uuid())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  householdId String
  name        String
  isLow       Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([householdId, name])
  @@index([householdId])
}

model LandlordProperty {
  id             String       @id @default(uuid())
  landlord       User         @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  landlordId     String
  household      Household    @relation(fields: [householdId], references: [id], onDelete: Cascade)
  householdId    String
  mode           LandlordMode @default(observer)
  consentGranted Boolean      @default(false)
  linkedAt       DateTime     @default(now())

  @@unique([landlordId, householdId])
  @@index([landlordId])
}

model HouseholdMember {
  id             String                @id @default(uuid())
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  household      Household             @relation(fields: [householdId], references: [id], onDelete: Cascade)
  householdId    String
  role           HouseholdRole         @default(member)
  status         MembershipStatus      @default(active)
  inactiveFrom   DateTime?
  inactiveUntil  DateTime?
  inactiveReason String?               @db.Text
  joinedAt       DateTime              @default(now())
  statusLogs     MembershipStatusLog[]

  @@unique([userId, householdId])
  @@index([householdId])
  @@index([householdId, status])
}

model Task {
  id             String     @id @default(uuid())
  household      Household  @relation(fields: [householdId], references: [id], onDelete: Cascade)
  householdId    String
  title          String
  titleSlug      String     @default("")
  weight         TaskWeight
  kind           TaskKind    @default(routine)
  cadence        TaskCadence @default(once)
  status         TaskStatus  @default(pending)
  dueAt          DateTime
  assignee       User       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  assigneeId     String
  flaggedBy      User?      @relation("TaskFlagger", fields: [flaggedById], references: [id])
  flaggedById    String?
  rotationReason String?    @db.Text
  completedBy    User?      @relation("TaskCompleter", fields: [completedById], references: [id])
  completedById  String?
  completedAt    DateTime?
  beforePhotoUrl String?    @db.Text
  proofPhotoUrl  String?    @db.Text
  snoozeUsed     Boolean    @default(false)
  penaltyApplied Boolean    @default(false)
  caretakerOwned Boolean    @default(false)
  messFlags      MessFlag[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([householdId, status])
  @@index([householdId, kind, status])
  @@index([assigneeId, status])
  @@index([householdId, title, completedAt])
  @@index([householdId, titleSlug, completedAt])
}

model Ritual {
  id           String              @id @default(uuid())
  household    Household           @relation(fields: [householdId], references: [id], onDelete: Cascade)
  householdId  String
  type         RitualType
  title        String
  proposedAt   DateTime
  status       RitualStatus        @default(proposed)
  cadence      RitualCadence       @default(once)
  proposer     User                @relation("RitualProposer", fields: [proposerId], references: [id], onDelete: Cascade)
  proposerId   String
  completedAt  DateTime?
  participants RitualParticipant[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([householdId, status])
}

model RitualParticipant {
  id       String   @id @default(uuid())
  ritual   Ritual   @relation(fields: [ritualId], references: [id], onDelete: Cascade)
  ritualId String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  joinedAt DateTime @default(now())

  @@unique([ritualId, userId])
  @@index([ritualId])
}

model MessFlag {
  id          String    @id @default(uuid())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  householdId String
  flagger     User      @relation("MessFlagger", fields: [flaggerId], references: [id])
  flaggerId   String
  task        Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  taskId      String?
  title       String
  photoUrl    String    @db.Text
  createdAt   DateTime  @default(now())

  @@index([householdId, createdAt])
  @@index([flaggerId])
}

model MembershipStatusLog {
  id           String           @id @default(uuid())
  membership   HouseholdMember  @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  membershipId String
  changedBy    User             @relation("MembershipStatusChanger", fields: [changedById], references: [id])
  changedById  String
  fromStatus   MembershipStatus
  toStatus     MembershipStatus
  from         DateTime?
  until        DateTime?
  reason       String?          @db.Text
  createdAt    DateTime         @default(now())

  @@index([membershipId, createdAt])
}

// A shared cost one resident fronted for the house. The creator is the payer
// (creditor); the corrected total is split equally across the included debtors.
// Money is tenant-only and never reaches the landlord portal.
model Expense {
  id          String         @id @default(uuid())
  household   Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  householdId String
  creator     User           @relation("ExpenseCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId   String
  title       String
  note        String?        @db.Text
  totalCents  Int
  receiptUrl  String?        @db.Text
  items       ExpenseItem[]
  shares      ExpenseShare[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([householdId, createdAt])
}

// Corrected line items from the receipt, kept as a review aid. The split maths
// is always on Expense.totalCents, never re-derived from these.
model ExpenseItem {
  id          String  @id @default(uuid())
  expense     Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  expenseId   String
  label       String
  amountCents Int
  position    Int

  @@index([expenseId])
}

// One debtor's portion of a bill, settled by a two-sided handshake: the debtor
// marks it paid (optionally with a proof image), then the creator confirms.
model ExpenseShare {
  id          String             @id @default(uuid())
  expense     Expense            @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  expenseId   String
  debtor      User               @relation("ExpenseDebtor", fields: [debtorId], references: [id], onDelete: Cascade)
  debtorId    String
  amountCents Int
  status      ExpenseShareStatus @default(open)
  proofUrl    String?            @db.Text
  paidAt      DateTime?
  confirmedAt DateTime?

  @@unique([expenseId, debtorId])
  @@index([expenseId])
}
