{
  "name": "homebuddy",
  "version": "0.1.0",
  "private": true,
  "description": "HomeBuddy — roommate/household task manager. API-first monorepo (NestJS + Next.js).",
  "packageManager": "pnpm@10.6.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @homebuddy/api prisma:migrate",
    "db:seed": "pnpm --filter @homebuddy/api prisma:seed",
    "db:reset": "pnpm --filter @homebuddy/api prisma:reset",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "3.3.3",
    "turbo": "2.3.3",
    "typescript": "5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
