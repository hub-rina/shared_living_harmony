# Database
DATABASE_URL="postgresql://homebuddy:homebuddy@localhost:5433/homebuddy?schema=public"

# API
API_PORT=4000
API_URL=http://localhost:4000

# JWT
JWT_ACCESS_SECRET=replace-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=replace-me-refresh-secret-min-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000

# Image storage (receipts + proof-of-payment for cost sharing)
# local  = store on the API's disk, served at /api/uploads (dev default, zero config)
# s3     = store in any S3-compatible bucket (Cloudflare R2 or self-hosted MinIO)
STORAGE_DRIVER=local
# Absolute base URL of the API, used to build local upload URLs. Set to the
# deployed API domain in production.
API_PUBLIC_URL=http://localhost:4000
# Only needed when STORAGE_DRIVER=s3:
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=
